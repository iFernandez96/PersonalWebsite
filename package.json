		"@tailwindcss/vite": "^4.3.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.8",
		"wrangler": "^4.68.0"
	},
	"dependencies": {
		"@fontsource/inter": "^5.2.8",
