{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "personalwebsite",
	"main": ".svelte-kit/cloudflare/_worker.js",
	"compatibility_date": "2026-04-24",
	"compatibility_flags": ["nodejs_compat"],
	"assets": {
		"directory": ".svelte-kit/cloudflare",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	}
}
